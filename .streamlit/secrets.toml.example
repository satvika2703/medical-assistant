# This file is a TEMPLATE for Streamlit Community Cloud secrets.
#
# Do NOT commit a real secrets.toml with actual keys to GitHub.
# Instead, when deploying on https://share.streamlit.io:
#   1. Go to your app's settings -> "Secrets"
#   2. Paste the contents below (with your real values) into that box
#
# Locally, you can copy this file to .streamlit/secrets.toml and fill it in
# (it's gitignored by default in most templates — double check).

GEMINI_API_KEY = "your_gemini_key_here"
SENDER_EMAIL = "your_gmail@gmail.com"
SENDER_PASSWORD = "your_app_password_here"
